{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "eara/eara-chart",
  "title": "Eara Chart",
  "category": "eara",
  "icon": "chart-bar",
  "description": "Bloco de gráfico avançado com variantes BarChart e DonutChart usando Mantine Charts",
  "supports": {
    "html": false
  },
  "attributes": {
    "variant": {
      "type": "string",
      "enum": [
        "bar",
        "donut"
      ],
      "default": "bar"
    },
    "chartLabel": {
      "type": "string",
      "default": "Chart Title"
    },
    "dataSourceType": {
      "type": "string",
      "enum": [
        "manual",
        "data-chart"
      ],
      "default": "manual"
    },
    "dataChartId": {
      "type": "number",
      "default": 0
    },
    "data": {
      "type": "array",
      "default": [
        {
          "month": "January",
          "Pigs": 1200,
          "Mice": 900,
          "Rats": 0
        },
        {
          "month": "February",
          "Pigs": 1900,
          "Mice": 1200,
          "Rats": 400
        },
        {
          "month": "March",
          "Pigs": 0,
          "Mice": 1000,
          "Rats": 200
        },
        {
          "month": "April",
          "Pigs": 1000,
          "Mice": 200,
          "Rats": 800
        },
        {
          "month": "May",
          "Pigs": 800,
          "Mice": 0,
          "Rats": 1200
        },
        {
          "month": "June",
          "Pigs": 0,
          "Mice": 600,
          "Rats": 1000
        }
      ]
    },
    "series": {
      "type": "array",
      "default": [
        {
          "name": "Pigs",
          "color": "violet.6"
        },
        {
          "name": "Mice",
          "color": "blue.6"
        },
        {
          "name": "Rats",
          "color": "teal.6"
        }
      ]
    },
    "dataKey": {
      "type": "string",
      "default": "month"
    },
    "orientation": {
      "type": "string",
      "enum": [
        "vertical",
        "horizontal"
      ],
      "default": "vertical"
    },
    "type": {
      "type": "string",
      "enum": [
        "default",
        "stacked",
        "percent"
      ],
      "default": "default"
    },
    "unit": {
      "type": "string",
      "default": ""
    },
    "withBarValueLabel": {
      "type": "boolean",
      "default": false
    },
    "tooltipDataSource": {
      "type": "string",
      "enum": [
        "segment",
        "all"
      ],
      "default": "all"
    },
    "height": {
      "type": "number",
      "default": 300
    },
    "withLegend": {
      "type": "boolean",
      "default": true
    },
    "yAxisLabel": {
      "type": "string",
      "default": ""
    },
    "xAxisLabel": {
      "type": "string",
      "default": ""
    },
    "gridAxis": {
      "type": "string",
      "enum": [
        "none",
        "x",
        "y",
        "xy"
      ],
      "default": "y"
    },
    "donutSize": {
      "type": "number",
      "default": 240
    },
    "donutThickness": {
      "type": "number",
      "default": 22
    },
    "donutWithLabels": {
      "type": "boolean",
      "default": true
    },
    "donutWithLabelsLine": {
      "type": "boolean",
      "default": true
    },
    "donutData": {
      "type": "array",
      "default": [
        {
          "name": "Pigs",
          "value": 400,
          "color": "indigo.6"
        },
        {
          "name": "Mice",
          "value": 300,
          "color": "yellow.6"
        },
        {
          "name": "Rats",
          "value": 100,
          "color": "teal.6"
        },
        {
          "name": "Other",
          "value": 200,
          "color": "gray.6"
        }
      ]
    }
  },
  "textdomain": "eara",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./index.css",
  "viewScript": "file:./frontend.js"
}